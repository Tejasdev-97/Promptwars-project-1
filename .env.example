# StadiumIQ Environment Template
# Copy this file to .env and fill in your actual API keys

# Google AI (Gemini)
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps Platform (Maps, TTS, Translate)
# Get your keys at: https://console.cloud.google.com/
GOOGLE_MAPS_KEY=your_google_maps_key_here
GOOGLE_TTS_KEY=your_google_tts_key_here
GOOGLE_TRANSLATE_KEY=your_google_translate_key_here

# Firebase Config (for Firestore real-time data)
VITE_FIREBASE_API_KEY=your_key
VITE_FIREBASE_AUTH_DOMAIN=your_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
